# Copy to .env and fill in real values before running

# Server
PORT=3000

# Gemini API key for the AI design agent (design_modify tool).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Used by estimate_cost tool to geocode a location into a city/region
GOOGLE_MAPS_API_KEY=

# Used by estimate_cost tool as a fallback / live rate lookup
# (any web-search-capable API key you wire up, e.g. Serper, Brave Search, etc.)
WEB_SEARCH_API_KEY=

# Optional: swap in a real vision/segmentation backend later.
# For the MVP, generate_3d_shell uses a stub extractor (see houseplan.vision.ts).
VISION_MODEL_ENDPOINT=
