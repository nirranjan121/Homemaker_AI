{
  "name": "homecraft-mcp",
  "version": "0.1.0",
  "description": "MCP server that turns a 2D house floor plan into an interactive 3D shell, with material editing and rough cost estimation, rendered via NitroStack widgets.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nitrostack/core": "^1.0.0",
    "@nitrostack/widgets": "^1.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
